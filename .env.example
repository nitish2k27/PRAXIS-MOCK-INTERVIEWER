# Root .env.example. Apps each have their own (apps/api/.env.example, apps/web/.env.example).
# Copy to .env in each app when running locally (uvicorn / npm run dev).
# When using docker-compose, the api container reads apps/api/.env, the web container reads apps/web/.env.

# See apps/api/.env.example and apps/web/.env.example for the full per-app env.
