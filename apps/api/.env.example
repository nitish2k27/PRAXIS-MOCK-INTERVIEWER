# API
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=dev

# Database (async URL — asyncpg)
# Host runs (uvicorn/alembic on your machine) use localhost; inside Docker use the
# service name `postgres`. The compose stack publishes Postgres to localhost:5432.
DATABASE_URL=postgresql+asyncpg://praxis:praxis_dev@localhost:5432/praxis

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — JWT
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14

# Auth — Google OIDC (create credentials at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8000/auth/google/callback

# Web app
WEB_BASE_URL=http://localhost:5173

# Cookies (set COOKIE_SECURE=true in prod)
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# Session middleware (Authlib state)
SESSION_SECRET=session-secret-change-me

# Storage (local for dev; switch to s3 for R2/S3)
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./uploads
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=praxis
S3_PUBLIC_BASE_URL=

# AI providers (Phase 1+) — get a Groq key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Screening — fit score (Phase 1): fit = w_dense*cosine + w_coverage*LLM-coverage
FIT_W_DENSE=0.4
FIT_W_COVERAGE=0.6
FIT_PROCEED_THRESHOLD=0.6

# Screening — competency map weighting (Phase 1)
COMPETENCY_MATCH_THRESHOLD=0.6
COMPETENCY_MUST_HAVE_WEIGHT=1.0
COMPETENCY_REQUIRED_WEIGHT=0.6

# Screening — company archetype resolution (Phase 1)
DEFAULT_COMPANY_ARCHETYPE=faang-structured

# Chroma (Phase 1+)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Scoring (Phase 6)
LORA_SCORER_URL=http://localhost:9000

# CORS
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
